# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"
# Maximum connections held by the Postgres pool per server instance.
POSTGRES_POOL_MAX="10"
# Rolling 24-hour chat token limit per non-admin user.
CHAT_TOKEN_LIMIT_24H="20000"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
